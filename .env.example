# Configuración del Sistema de Asistencia con Reconocimiento Facial
# 
# INSTRUCCIONES:
# 1. Copia este archivo como .env en el mismo directorio
# 2. Personaliza los valores según tu configuración
# 3. NO commits el archivo .env a control de versiones (ya está en .gitignore)

# URL de la cámara IP (reemplaza la IP por la de tu celular)
# Formatos comunes:
#   - IP Webcam (Android): http://192.168.1.XXX:8080/video
#   - DroidCam: http://192.168.1.XXX:4747/video
#   - iVCam: http://192.168.1.XXX:PORT/video
CAMERA_URL=http://192.168.1.100:8080/video

# Modelo de reconocimiento facial
# Opciones: VGG-Face, Facenet512, ArcFace, DeepFace, etc.
MODEL_NAME=Facenet512

# Backend de detección de rostros
# Opciones: opencv, retinaface, mtcnn, ssd, mediapipe
DETECTOR_BACKEND=retinaface

# Ruta a la base de datos de rostros
DB_PATH=data/deepface/face_db

# Ruta al archivo CSV de asistencia
CSV_PATH=data/deepface/attendance/attendance.csv

# Umbral de similitud (0.0 a 1.0, valores más bajos son más estrictos)
# Recomendado: 0.4-0.5 para Facenet512 con cosine distance
THRESHOLD=0.4

# Segundos para considerar un registro como duplicado (dedupe)
# Evita registrar la misma persona múltiples veces en corto tiempo
DEDUPE_SECONDS=300
